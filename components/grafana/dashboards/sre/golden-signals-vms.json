        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (name) (rate(kubevirt_vmi_vcpu_delay_seconds_total{namespace=~\"$namespace\",name=~\"$vm\"}[$__rate_interval]))",
          "legendFormat": "{{name}} delay"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Memory",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
