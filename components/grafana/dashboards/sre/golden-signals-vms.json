          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (name) (kubevirt_vmi_memory_resident_bytes{namespace=~\"$namespace\",name=~\"$vm\"})",
          "legendFormat": "{{name}} host RSS (working set)"
        },
        {
