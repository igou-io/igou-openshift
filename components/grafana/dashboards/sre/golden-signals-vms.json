{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "thanos-querier",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "schemaVersion": 39,
  "uid": "sre-kubevirt-golden",
  "title": "Golden Signals \u2014 KubeVirt VMs",
  "description": "Per-VM RED/USE from kubevirt_vmi_* (platform prometheus, job=kubevirt-prometheus-metrics; OCP-local VMs only \u2014 federated rk8s has no VMs). Signals: traffic = CPU cores / network throughput / storage iops; latency-proxy = storage read/write avg service time (rate(times_seconds)/rate(iops)) \u2014 KubeVirt exposes no request-latency histogram, so there is no VM-level RED duration percentile; errors = network rx/tx errors+drops; saturation = CPU utilization vs allocated vCPU, vCPU wait/delay (steal), memory footprint. NOTE on memory: KubeVirt has no cadvisor-style 'working set' gauge for VMs \u2014 host working set is approximated by kubevirt_vmi_memory_resident_bytes (virt-launcher RSS); guest-internal used/total come from kubevirt_vmi_memory_used_bytes / _available_bytes (require guest-agent). Gaps vs a full golden-signal board: no node PSI (collector disabled cluster-wide) and no per-VM latency histogram, so saturation leans on CPU/steal proxies.",
  "tags": [
    "sre"
  ],
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": false,
  "timepicker": {
    "refresh_intervals": [
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "label_values(kubevirt_vmi_vcpu_count, namespace)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {}
      },
      {
        "name": "vm",
        "label": "VM",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "label_values(kubevirt_vmi_vcpu_count{namespace=~\"$namespace\"}, name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Fleet Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CPU Used (cores)",
      "description": "Aggregate CPU consumption of selected VMs from rate(kubevirt_vmi_cpu_usage_seconds_total).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(kubevirt_vmi_cpu_usage_seconds_total{namespace=~\"$namespace\",name=~\"$vm\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "vCPUs Allocated",
      "description": "Sum of kubevirt_vmi_vcpu_count across selected VMs (denominator for utilization).",
