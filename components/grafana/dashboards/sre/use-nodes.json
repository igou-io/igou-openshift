          "expr": "100 * (1 - avg by (cluster, instance) (rate(node_cpu_seconds_total{cluster=~\"$cluster\", instance=~\"$node\", mode=\"idle\"}[$__rate_interval])))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU saturation \u2014 load per core (S)",
      "description": "node_load1 divided by core count (1.0 = fully committed run queue). PSI is unavailable on these nodes (node_pressure_* does not exist), so 1-minute loadavg is used as the run-queue saturation proxy.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "node_load1{cluster=~\"$cluster\", instance=~\"$node\"} / on(cluster, instance) count by (cluster, instance) (count by (cluster, instance, cpu) (node_cpu_seconds_total{cluster=~\"$cluster\", instance=~\"$node\", mode=\"idle\"}))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
