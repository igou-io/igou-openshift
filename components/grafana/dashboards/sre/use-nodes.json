{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "thanos-querier",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "sre"
  ],
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": false,
  "timepicker": {
    "refresh_intervals": [
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "title": "USE \u2014 Nodes",
  "uid": "use-nodes",
  "description": "Utilization / Saturation / Errors for every node across BOTH clusters. Cluster label quirk: OCP node-exporter carries an EMPTY cluster label (matched with cluster=~\"^$\") and uses hostname as instance; federated rk8s carries cluster=\"rk8s\" and uses <IP>:9100 as instance. Saturation gaps: node PSI (node_pressure_*) does NOT exist \u2014 the node-exporter PSI collector is disabled on OCP RHCOS and PSI is not in the rk8s federation allowlist \u2014 so CPU saturation falls back to loadavg (node_load1 normalized by core count) and memory saturation falls back to swap-in-use, not true PSI stall time. All series use only metrics confirmed present in the node-exporter families node_cpu_*/node_memory_*/node_disk_*/node_network_*.",
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "cluster",
        "type": "custom",
        "description": "OCP metrics have an empty cluster label; rk8s metrics are stamped cluster=rk8s. Values are regexes matched with =~.",
        "query": "ocp : ^$,rk8s : rk8s",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "$__all"
          },
          {
            "selected": false,
            "text": "ocp",
            "value": "^$"
          },
          {
            "selected": false,
            "text": "rk8s",
            "value": "rk8s"
          }
        ],
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "node",
        "label": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(node_cpu_seconds_total{cluster=~\"$cluster\"}, instance)",
        "query": {
          "qryType": 1,
          "query": "label_values(node_cpu_seconds_total{cluster=~\"$cluster\"}, instance)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Nodes reporting",
      "description": "Distinct node-exporter instances matching the current $cluster/$node selection.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "count(count by (cluster, instance) (node_cpu_seconds_total{cluster=~\"$cluster\", instance=~\"$node\"}))",
          "instant": true,
          "legendFormat": "nodes"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Peak CPU utilization",
      "description": "Highest busy-CPU percentage across the selected nodes (1 - idle).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max(100 * (1 - avg by (cluster, instance) (rate(node_cpu_seconds_total{cluster=~\"$cluster\", instance=~\"$node\", mode=\"idle\"}[$__rate_interval]))))",
          "legendFormat": "peak cpu"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Peak memory utilization",
      "description": "Highest used-memory percentage across the selected nodes (1 - MemAvailable/MemTotal).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
