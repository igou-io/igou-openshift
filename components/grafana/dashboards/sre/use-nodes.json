            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max(100 * (1 - node_memory_MemAvailable_bytes{cluster=~\"$cluster\", instance=~\"$node\"} / node_memory_MemTotal_bytes{cluster=~\"$cluster\", instance=~\"$node\"}))",
          "legendFormat": "peak mem"
        }
      ]
    },
    {
      "id": 5,
