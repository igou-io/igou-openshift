{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_LOKI_INFRASTRUCTURE",
      "label": "Loki (infrastructure tenant)",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "Log Gateway (syslog ingress)",
  "uid": "log-gateway-syslog",
  "tags": ["logging", "log-gateway"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Syslog entries received /s",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "cps", "min": 0}, "overrides": []},
      "targets": [
        {
          "expr": "sum by (component_id) (rate(loki_source_syslog_entries_total{namespace=\"log-gateway\"}[$__rate_interval]))",
          "legendFormat": "{{component_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Ingest problems /s (parse errors, empty messages)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "cps", "min": 0}, "overrides": []},
      "targets": [
        {
          "expr": "sum(rate(loki_source_syslog_parsing_errors_total{namespace=\"log-gateway\"}[$__rate_interval]))",
          "legendFormat": "parsing errors",
          "refId": "A"
        },
        {
          "expr": "sum(rate(loki_source_syslog_empty_messages_total{namespace=\"log-gateway\"}[$__rate_interval]))",
          "legendFormat": "empty messages",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Forwarded to LokiStack /s (sent, dropped, retries)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "cps", "min": 0}, "overrides": []},
      "targets": [
        {
          "expr": "sum(rate(loki_write_sent_entries_total{namespace=\"log-gateway\"}[$__rate_interval]))",
          "legendFormat": "sent",
          "refId": "A"
        },
        {
          "expr": "sum(rate(loki_write_dropped_entries_total{namespace=\"log-gateway\"}[$__rate_interval]))",
          "legendFormat": "dropped",
          "refId": "B"
        },
        {
          "expr": "sum(rate(loki_write_batch_retries_total{namespace=\"log-gateway\"}[$__rate_interval]))",
          "legendFormat": "batch retries",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Write latency (p99 request, p95 end-to-end propagation)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(loki_write_request_duration_seconds_bucket{namespace=\"log-gateway\"}[$__rate_interval])))",
          "legendFormat": "request p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(loki_write_entry_propagation_latency_seconds_bucket{namespace=\"log-gateway\"}[$__rate_interval])))",
          "legendFormat": "propagation p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Syslog lines by device (infrastructure tenant)",
      "type": "timeseries",
      "datasource": {"type": "loki", "uid": "${DS_LOKI_INFRASTRUCTURE}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "fieldConfig": {"defaults": {"min": 0}, "overrides": []},
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({job=\"syslog\"}[$__auto]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    }
  ]
}
