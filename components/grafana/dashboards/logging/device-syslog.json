{
  "__inputs": [
    {
      "name": "DS_LOKI_INFRASTRUCTURE",
      "label": "loki-infrastructure",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "Device Syslog",
  "uid": "device-syslog",
  "description": "Appliance/device syslog through the log-gateway (RouterOS, TrueNAS, future Synology/HA/UniFi) \u2014 igou-openshift#382.",
  "tags": [
    "logging"
  ],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Device",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_INFRASTRUCTURE}"
        },
        "query": "label_values({job=\"syslog\"}, host)",
        "definition": "label_values({job=\"syslog\"}, host)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "sort": 1
      },
      {
        "name": "level",
        "label": "Severity",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_INFRASTRUCTURE}"
        },
        "query": "label_values({job=\"syslog\", host=~\"$host\"}, level)",
        "definition": "label_values({job=\"syslog\", host=~\"$host\"}, level)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "sort": 1
      },
      {
        "name": "search",
        "label": "Line contains",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Syslog volume by device",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "sum by (host) (count_over_time({job=\"syslog\", host=~\"$host\"}[$__auto]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Volume by severity",
      "description": "Severity from the syslog PRI relabel (level label).",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "sum by (level) (count_over_time({job=\"syslog\", host=~\"$host\", level=~\"$level\"}[$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Login failures (RouterOS)",
      "description": "Feeds the RouterOSLoginFailures alert (>3 in 15m).",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "sum by (host) (count_over_time({job=\"syslog\", host=~\"$host\"} |= `login failure` [$__auto]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Lines per device (range)",
      "description": "A device at zero here for a day trips SyslogRouterOSSilent.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 6
      },
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlPu"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "sum by (host) (count_over_time({job=\"syslog\", host=~\"$host\"}[$__range]))",
          "legendFormat": "{{host}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Device lines",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 12
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "{job=\"syslog\", host=~\"$host\", level=~\"$level\"} |~ `$search`",
          "refId": "A"
        }
      ]
    }
  ]
}
