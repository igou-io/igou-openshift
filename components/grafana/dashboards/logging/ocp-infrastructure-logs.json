{
  "__inputs": [
    {
      "name": "DS_LOKI_INFRASTRUCTURE",
      "label": "loki-infrastructure",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "ocp Infrastructure Logs",
  "uid": "ocp-infrastructure-logs",
  "description": "ocp node journals + infrastructure-namespace pod logs. Audit tenant is deliberately Grafana-excluded (admin/CLI only) \u2014 igou-openshift#382.",
  "tags": [
    "logging"
  ],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_INFRASTRUCTURE}"
        },
        "definition": "label_values({log_type=\"infrastructure\"}, kubernetes_host)",
        "query": "label_values({log_type=\"infrastructure\"}, kubernetes_host)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "namespace",
        "label": "Infra namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_INFRASTRUCTURE}"
        },
        "definition": "label_values({log_type=\"infrastructure\", kubernetes_namespace_name=~\".+\"}, kubernetes_namespace_name)",
        "query": "label_values({log_type=\"infrastructure\", kubernetes_namespace_name=~\".+\"}, kubernetes_namespace_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "search",
        "label": "Line contains",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Node journal volume",
      "description": "journald streams have no namespace label \u2014 empty-label matcher isolates them.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "sum by (kubernetes_host) (count_over_time({log_type=\"infrastructure\", kubernetes_namespace_name=\"\", kubernetes_host=~\"$node\"}[$__auto]))",
          "legendFormat": "{{kubernetes_host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Infra pod volume by namespace",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "sum by (kubernetes_namespace_name) (count_over_time({log_type=\"infrastructure\", kubernetes_namespace_name=~\"$namespace\"}[$__auto]))",
          "legendFormat": "{{kubernetes_namespace_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error-ish node journal lines",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "sum by (kubernetes_host) (count_over_time({log_type=\"infrastructure\", kubernetes_namespace_name=\"\", kubernetes_host=~\"$node\"} |~ `(?i)(error|fail|panic|oom)` [$__auto]))",
          "legendFormat": "{{kubernetes_host}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Noisiest infra namespaces (range)",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 6
      },
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlPu"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "topk(10, sum by (kubernetes_namespace_name) (count_over_time({log_type=\"infrastructure\", kubernetes_namespace_name=~\"$namespace\"}[$__range])))",
          "legendFormat": "{{kubernetes_namespace_name}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Node journals",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 9
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "{log_type=\"infrastructure\", kubernetes_namespace_name=\"\", kubernetes_host=~\"$node\"} |~ `$search`",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Infra pod lines",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 9
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "{log_type=\"infrastructure\", kubernetes_namespace_name=~\"$namespace\"} |~ `$search`",
          "refId": "A"
        }
      ]
    }
  ]
}
