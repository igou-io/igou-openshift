{
  "__inputs": [
    {
      "name": "DS_LOKI_APPLICATION",
      "label": "loki-application",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "sands-of-time",
  "uid": "sands-of-time-logs",
  "description": "sands-of-time app logs (application tenant) \u2014 igou-openshift#382. Default 1h window with auto-refresh off: widen the range deliberately and refresh manually \u2014 widened-range + auto-refresh is the expensive combination on the small Loki.",
  "tags": [
    "logging"
  ],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": false,
  "timepicker": {
    "refresh_intervals": [
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_APPLICATION}"
        },
        "definition": "label_values({log_type=\"application\", kubernetes_namespace_name=\"sands-of-time\"}, kubernetes_pod_name)",
        "query": "label_values({log_type=\"application\", kubernetes_namespace_name=\"sands-of-time\"}, kubernetes_pod_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "search",
        "label": "Line contains",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Lines (range)",
      "description": "Neutral by design \u2014 red is reserved for errors.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum (count_over_time({log_type=\"application\", kubernetes_namespace_name=\"sands-of-time\"}[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error-ish lines (range)",
      "description": "Same expression as the error trend below, as a glance tile.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 10
              },
              {
                "color": "#F2495C",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum (count_over_time({log_type=\"application\", kubernetes_namespace_name=\"sands-of-time\"} |~ `(?i)(error|fail|traceback|exception)` [$__range]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Volume by pod",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum by (kubernetes_pod_name) (count_over_time({log_type=\"application\", kubernetes_namespace_name=\"sands-of-time\", kubernetes_pod_name=~\"$pod\"}[$__auto]))",
          "legendFormat": "{{kubernetes_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error-ish lines",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum (count_over_time({log_type=\"application\", kubernetes_namespace_name=\"sands-of-time\"} |~ `(?i)(error|fail|traceback|exception)` [$__auto]))",
          "legendFormat": "errors",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP requests",
      "description": "API access lines incl. the hermes ATL cron reads.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum (count_over_time({log_type=\"application\", kubernetes_namespace_name=\"sands-of-time\"} |~ `(GET|POST|PUT|DELETE) /` [$__auto]))",
          "legendFormat": "requests",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "sands-of-time lines",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 12
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "showLabels": false,
        "prettifyLogMessage": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "{log_type=\"application\", kubernetes_namespace_name=\"sands-of-time\", kubernetes_pod_name=~\"$pod\"} |= `$search`",
          "maxLines": 1000,
          "refId": "A"
        }
      ]
    }
  ]
}
