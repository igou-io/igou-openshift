{
  "__inputs": [
    {
      "name": "DS_LOKI_APPLICATION",
      "label": "loki-application",
      "type": "datasource",
      "pluginId": "loki"
    },
    {
      "name": "DS_LOKI_INFRASTRUCTURE",
      "label": "loki-infrastructure",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "KubeVirt VMs",
  "uid": "kubevirt-vms",
  "description": "KubeVirt VM host-side logs (virt-launcher pods) across namespaces; guest journals appear where the guest ships them \u2014 igou-openshift#382. Default 1h window with auto-refresh off: widen the range deliberately and refresh manually \u2014 widened-range + auto-refresh is the expensive combination on the small Loki.",
  "tags": [
    "logging"
  ],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": false,
  "timepicker": {
    "refresh_intervals": [
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "VM namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_APPLICATION}"
        },
        "definition": "label_values({log_type=\"application\", kubernetes_pod_name=~\"virt-launcher-.*\"}, kubernetes_namespace_name)",
        "query": "label_values({log_type=\"application\", kubernetes_pod_name=~\"virt-launcher-.*\"}, kubernetes_namespace_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "pod",
        "label": "virt-launcher pod",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_APPLICATION}"
        },
        "definition": "label_values({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\", kubernetes_pod_name=~\"virt-launcher-.*\"}, kubernetes_pod_name)",
        "query": "label_values({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\", kubernetes_pod_name=~\"virt-launcher-.*\"}, kubernetes_pod_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "search",
        "label": "Line contains",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "virt-launcher volume by VM pod",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum by (kubernetes_pod_name) (count_over_time({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\", kubernetes_pod_name=~\"virt-launcher-.*\"}[$__auto]))",
          "legendFormat": "{{kubernetes_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error-ish launcher lines",
      "description": "Launcher/libvirt errors: stuck volume attach, migration, device issues.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum by (kubernetes_pod_name) (count_over_time({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\", kubernetes_pod_name=~\"virt-launcher-.*\"} |~ `(?i)(error|fail)` [$__auto]))",
          "legendFormat": "{{kubernetes_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "virt-launcher lines (qemu/libvirt/hypervisor)",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 10
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "showLabels": false,
        "prettifyLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "{log_type=\"application\", kubernetes_namespace_name=~\"$namespace\", kubernetes_pod_name=~\"$pod\"} |= `$search`",
          "maxLines": 1000,
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Guest journals (where shipped: hermes)",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_INFRASTRUCTURE}"
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 8
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "showLabels": false,
        "prettifyLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_INFRASTRUCTURE}"
          },
          "expr": "{job=\"systemd-journal\", host=\"hermes\"} |= `$search`",
          "maxLines": 1000,
          "refId": "A"
        }
      ]
    }
  ]
}
