{
  "__inputs": [
    {
      "name": "DS_LOKI_APPLICATION",
      "label": "loki-application",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "ocp Application Logs",
  "uid": "ocp-application-logs",
  "description": "ocp user-namespace pod logs (application tenant) \u2014 igou-openshift#382. STRESS-TESTED LIMIT: with All namespaces selected, the volume/error trend panels exceed Grafana's 30s query wall beyond ~24h of range (full-corpus scan on the 1x.demo querier) \u2014 narrow $namespace before widening the window. Default 1h window with auto-refresh off: widen the range deliberately and refresh manually \u2014 widened-range + auto-refresh is the expensive combination on the small Loki.",
  "tags": [
    "logging"
  ],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": false,
  "timepicker": {
    "refresh_intervals": [
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_APPLICATION}"
        },
        "definition": "label_values({log_type=\"application\"}, kubernetes_namespace_name)",
        "query": "label_values({log_type=\"application\"}, kubernetes_namespace_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI_APPLICATION}"
        },
        "definition": "label_values({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\"}, kubernetes_pod_name)",
        "query": "label_values({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\"}, kubernetes_pod_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "search",
        "label": "Line contains",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Volume by namespace",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum by (kubernetes_namespace_name) (count_over_time({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\"}[$__auto]))",
          "legendFormat": "{{kubernetes_namespace_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error-ish lines by namespace",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 4,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "sum by (kubernetes_namespace_name) (count_over_time({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\"} |~ `(?i)(error|fail|panic|fatal)` [$__auto]))",
          "legendFormat": "{{kubernetes_namespace_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Noisiest pods (last 6h)",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 6
      },
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlPu"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "topk(10, sum by (kubernetes_pod_name) (count_over_time({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\", kubernetes_pod_name=~\"$pod\"}[6h])))",
          "legendFormat": "{{kubernetes_pod_name}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Noisiest namespaces (last 6h)",
      "description": "Chronic top-talkers are retention/prune candidates.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 6
      },
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlPu"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "topk(10, sum by (kubernetes_namespace_name) (count_over_time({log_type=\"application\", kubernetes_namespace_name=~\"$namespace\"}[6h])))",
          "legendFormat": "{{kubernetes_namespace_name}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Pod lines",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI_APPLICATION}"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 12
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "showLabels": false,
        "prettifyLogMessage": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI_APPLICATION}"
          },
          "expr": "{log_type=\"application\", kubernetes_namespace_name=~\"$namespace\", kubernetes_pod_name=~\"$pod\"} |= `$search`",
          "maxLines": 1000,
          "refId": "A"
        }
      ]
    }
  ]
}
