      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "pool:truenas_disk_busy_ms:avg{pool=~\"$pool\"}",
          "legendFormat": "{{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Per-pool avg disk busy-time",
      "type": "timeseries"
    },
