          "expr": "sum by (pool, disk) (disk:truenas_disk_busy_ms{pool=~\"$pool\"}) / clamp_min(sum by (pool, disk) (disk:truenas_disk_iops{pool=~\"$pool\"}), 1)",
          "legendFormat": "{{pool}}/{{disk}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Per-disk avg service time",
