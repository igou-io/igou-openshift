{
  "annotations": {
    "list": []
  },
  "description": "TrueNAS exporter metrics from netdata, smartctl, and IPMI.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
