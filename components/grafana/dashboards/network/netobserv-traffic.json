{
 "__inputs": [
  {
   "name": "DS_PROMETHEUS",
   "label": "Prometheus",
   "type": "datasource",
   "pluginId": "prometheus"
  },
  {
   "name": "DS_LOKI_NETWORK",
   "label": "Loki (network tenant)",
   "type": "datasource",
   "pluginId": "loki"
  }
 ],
 "title": "NetObserv / Traffic Matrix",
 "uid": "netobserv-traffic",
 "tags": [
  "netobserv",
  "network"
 ],
 "schemaVersion": 39,
 "timezone": "browser",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "refresh": "1m",
 "templating": {
  "list": [
   {
    "name": "src_ns",
    "label": "source namespace",
    "type": "query",
    "datasource": {
     "type": "prometheus",
     "uid": "${DS_PROMETHEUS}"
    },
    "query": {
     "query": "label_values(netobserv_namespace_flows_total, SrcK8S_Namespace)",
     "refId": "v1"
    },
    "refresh": 2,
    "includeAll": true,
    "allValue": ".*",
    "multi": false,
    "current": {
     "selected": true,
     "text": "All",
     "value": "$__all"
    }
   },
   {
    "name": "dst_ns",
    "label": "destination namespace",
    "type": "query",
    "datasource": {
     "type": "prometheus",
     "uid": "${DS_PROMETHEUS}"
    },
    "query": {
     "query": "label_values(netobserv_namespace_flows_total, DstK8S_Namespace)",
     "refId": "v2"
    },
    "refresh": 2,
    "includeAll": true,
    "allValue": ".*",
    "multi": false,
    "current": {
     "selected": true,
     "text": "All",
     "value": "$__all"
    }
   }
  ]
 },
 "panels": [
  {
   "type": "stat",
   "title": "Flow records / s",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
   },
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 0,
    "y": 0
   },
   "targets": [
    {
     "expr": "sum(rate(netobserv_ingest_flows_processed[$__rate_interval]))",
     "refId": "A",
     "instant": false,
     "range": true,
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
     }
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value_and_name",
    "justifyMode": "auto"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "reqps",
     "decimals": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "text",
        "value": null
       }
      ]
     }
    },
    "overrides": []
   },
   "description": "Sampled flow records stored (eBPF sampling 1:50)."
  },
  {
   "type": "stat",
   "title": "Est. observed traffic",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
   },
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 6,
    "y": 0
   },
   "targets": [
    {
     "expr": "sum(rate(netobserv_workload_egress_bytes_total[$__rate_interval])) * 50",
     "refId": "A",
     "instant": false,
     "range": true,
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
     }
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value_and_name",
    "justifyMode": "auto"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "Bps",
     "decimals": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "text",
        "value": null
       }
      ]
     }
    },
    "overrides": []
   },
   "description": "Workload egress bytes, sampling-corrected (\u00d750). An estimate, not an exact meter."
  },
  {
   "type": "stat",
   "title": "Active ns\u2192ns pairs",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
   },
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 12,
    "y": 0
   },
   "targets": [
    {
     "expr": "count(sum by (SrcK8S_Namespace, DstK8S_Namespace) (increase(netobserv_namespace_flows_total{SrcK8S_Namespace!=\"\",DstK8S_Namespace!=\"\"}[$__range])) > 0)",
     "refId": "A",
     "instant": true,
     "range": false,
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
     }
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value_and_name",
    "justifyMode": "auto"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "decimals": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "text",
        "value": null
       }
      ]
     }
    },
    "overrides": []
   },
   "description": "Distinct namespace pairs with traffic in the dashboard time range \u2014 the rows your NetworkPolicies must cover."
  },
  {
   "type": "stat",
   "title": "Agent dropped flows / s",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
   },
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 18,
    "y": 0
   },
   "targets": [
    {
     "expr": "sum(rate(netobserv_agent_dropped_flows_total[$__rate_interval])) or vector(0)",
     "refId": "A",
     "instant": false,
     "range": true,
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
     }
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value_and_name",
    "justifyMode": "auto"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "reqps",
     "decimals": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "description": "eBPF agent drops. Non-zero means the flow picture is incomplete."
  },
  {
   "type": "timeseries",
   "title": "Traffic by destination namespace (est., \u00d750)",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
   },
   "gridPos": {
    "h": 10,
    "w": 14,
    "x": 0,
    "y": 4
   },
   "description": "Ingress bytes per destination namespace, sampling-corrected.",
   "targets": [
    {
     "expr": "sum by (DstK8S_Namespace) (rate(netobserv_workload_ingress_bytes_total{DstK8S_Namespace!=\"\"}[$__rate_interval])) * 50",
     "legendFormat": "{{DstK8S_Namespace}}",
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
     }
    }
   ],
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "bottom",
     "calcs": [
      "lastNotNull",
      "max"
     ]
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "fieldConfig": {
    "defaults": {
     "unit": "Bps",
     "custom": {
      "drawStyle": "line",
      "lineWidth": 2,
      "fillOpacity": 0,
      "pointSize": 4,
      "showPoints": "never",
      "spanNulls": true
     }
    },
    "overrides": []
   }
  },
  {
   "type": "table",
   "title": "Namespace \u2192 namespace matrix (sampled flows, range)",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
   },
   "gridPos": {
    "h": 19,
    "w": 10,
    "x": 14,
    "y": 4
   },
   "description": "Every namespace pair seen in the time range. This table IS the NetworkPolicy worklist; drill into ports below.",
   "targets": [
    {
     "expr": "sum by (SrcK8S_Namespace, DstK8S_Namespace) (increase(netobserv_namespace_flows_total{SrcK8S_Namespace!=\"\",DstK8S_Namespace!=\"\"}[$__range]))",
     "format": "table",
     "instant": true,
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
     }
    }
   ],
   "transformations": [
    {
     "id": "organize",
     "options": {
      "excludeByName": {
       "Time": true
      },
      "renameByName": {
       "SrcK8S_Namespace": "source",
       "DstK8S_Namespace": "destination",
       "Value": "flows"
      }
     }
    },
    {
     "id": "sortBy",
     "options": {
      "sort": [
       {
        "field": "flows",
        "desc": true
       }
      ]
     }
    }
   ],
   "options": {
    "footer": {
     "show": false
    },
    "showHeader": true
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "decimals": 0,
     "custom": {
      "align": "left"
     }
    },
    "overrides": [
     {
      "matcher": {
       "id": "byName",
       "options": "flows"
      },
      "properties": [
       {
        "id": "custom.cellOptions",
        "value": {
         "type": "gauge",
         "mode": "basic"
        }
       },
       {
        "id": "color",
        "value": {
         "mode": "fixed",
         "fixedColor": "blue"
        }
       }
      ]
     }
    ]
   }
  },
  {
   "type": "bargauge",
   "title": "Top destination workloads (ingress, est. \u00d750)",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
   },
   "gridPos": {
    "h": 9,
    "w": 7,
    "x": 0,
    "y": 14
   },
   "targets": [
    {
     "expr": "topk(10, sum by (DstK8S_Namespace, DstK8S_OwnerName) (rate(netobserv_workload_ingress_bytes_total{DstK8S_OwnerName!=\"\"}[$__range])) * 50)",
     "legendFormat": "{{DstK8S_Namespace}}/{{DstK8S_OwnerName}}",
     "instant": true,
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
     }
    }
   ],
   "options": {
    "orientation": "horizontal",
    "displayMode": "basic",
    "valueMode": "color",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "showUnfilled": true
   },
   "fieldConfig": {
    "defaults": {
     "unit": "Bps",
     "decimals": 1,
     "color": {
      "mode": "fixed",
      "fixedColor": "blue"
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "blue",
        "value": null
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "type": "bargauge",
   "title": "Top source workloads (egress, est. \u00d750)",
   "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
   },
   "gridPos": {
    "h": 9,
    "w": 7,
    "x": 7,
    "y": 14
   },
   "targets": [
    {
     "expr": "topk(10, sum by (SrcK8S_Namespace, SrcK8S_OwnerName) (rate(netobserv_workload_egress_bytes_total{SrcK8S_OwnerName!=\"\"}[$__range])) * 50)",
     "legendFormat": "{{SrcK8S_Namespace}}/{{SrcK8S_OwnerName}}",
     "instant": true,
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
     }
    }
   ],
   "options": {
    "orientation": "horizontal",
    "displayMode": "basic",
    "valueMode": "color",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "showUnfilled": true
   },
   "fieldConfig": {
    "defaults": {
     "unit": "Bps",
     "decimals": 1,
     "color": {
      "mode": "fixed",
      "fixedColor": "purple"
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "purple",
        "value": null
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "type": "timeseries",
   "title": "Flow rate for selection ($src_ns \u2192 $dst_ns)",
   "datasource": {
    "type": "loki",
    "uid": "${DS_LOKI_NETWORK}"
   },
   "gridPos": {
    "h": 8,
    "w": 24,
    "x": 0,
    "y": 23
   },
   "description": "Sampled flow records/s matching the source/destination namespace filters above.",
   "targets": [
    {
     "expr": "sum(count_over_time({app=\"netobserv-flowcollector\"} | SrcK8S_Namespace=~\"$src_ns\" | DstK8S_Namespace=~\"$dst_ns\" [$__auto]))",
     "refId": "A",
     "datasource": {
      "type": "loki",
      "uid": "${DS_LOKI_NETWORK}"
     }
    }
   ],
   "options": {
    "legend": {
     "displayMode": "hidden"
    },
    "tooltip": {
     "mode": "single"
    }
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "custom": {
      "drawStyle": "bars",
      "lineWidth": 1,
      "fillOpacity": 60,
      "barAlignment": 0
     }
    },
    "overrides": []
   }
  },
  {
   "type": "logs",
   "title": "Flow drill-down ($src_ns \u2192 $dst_ns) \u2014 pods & ports",
   "datasource": {
    "type": "loki",
    "uid": "${DS_LOKI_NETWORK}"
   },
   "gridPos": {
    "h": 12,
    "w": 24,
    "x": 0,
    "y": 31
   },
   "description": "Per-flow records: pod \u2192 pod with destination port and protocol. Bytes/packets are per sampled record (\u00d750 \u2248 actual). The gateway rejects regex in stream selectors \u2014 namespace filters are pipeline label filters.",
   "targets": [
    {
     "expr": "{app=\"netobserv-flowcollector\"} | SrcK8S_Namespace=~\"$src_ns\" | DstK8S_Namespace=~\"$dst_ns\" | json | line_format \"{{.SrcK8S_Namespace}}/{{.SrcK8S_Name}} \u2192 {{.DstK8S_Namespace}}/{{.DstK8S_Name}}  :{{.DstPort}}  proto={{.Proto}}  {{.Bytes}}B/{{.Packets}}p\"",
     "refId": "A",
     "datasource": {
      "type": "loki",
      "uid": "${DS_LOKI_NETWORK}"
     }
    }
   ],
   "options": {
    "showTime": true,
    "wrapLogMessage": false,
    "enableLogDetails": true,
    "dedupStrategy": "none",
    "sortOrder": "Descending"
   }
  }
 ]
}